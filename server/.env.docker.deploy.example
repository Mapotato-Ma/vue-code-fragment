# 复制为 .env.docker.deploy 后填写（该文件已加入 .gitignore）
# 方案：本地 docker build + save → scp tar → 远端 docker load + run
# DEPLOY_HOST：与 ~/.ssh/config 中 Host 一致（本仓库示例使用别名「腾讯云」）
# 本文件请用 UTF-8 保存（含中文 Host 时必选），否则 Windows 下 ssh 可能解析成乱码主机名

DEPLOY_HOST=腾讯云
DEPLOY_USER=root

# 远端存放 tar 的目录（须可写；脚本会先 mkdir -p）
REMOTE_DIR=/opt/mapotato-api

# 容器名、宿主机映射端口（容器内固定 3638）
CONTAINER_NAME=mapotato-api
HOST_PORT=3638

# 可选：宿主机目录挂载为 /app/data（放 pens.json），不配则使用镜像内打包的 data
# DATA_VOLUME_HOST=/opt/mapotato-api/data

# 可选：部署后保留本机 mapotato-api.tar（默认删除）
# KEEP_LOCAL_TAR=1
