{
  "name": "server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "轻量 JSON API（Node + TypeScript），为 vue-demos 提供 CodePen 列表",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "docker:build": "docker build -t mapotato-api:local .",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:deploy": "powershell -ExecutionPolicy Bypass -File ./scripts/docker-deploy.ps1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.4",
    "typescript": "~5.7.3"
  }
}
