{
  "name": "vue-demos",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "run-p type-check \"build-only {@}\" --",
    "build-upload": "run-s build cls zip cls upload cls unzip",
    "upload-unzip": "run-s upload cls unzip",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "format": "prettier --write src/",
    "zip": "powershell -Command \"Compress-Archive -Path ./mapotato/* mapotato.zip -Force\"",
    "upload": "scp ./mapotato.zip 腾讯云:/var/www/html/",
    "unzip": "ssh 腾讯云 unzip -o /var/www/html/mapotato.zip -d /var/www/html/mapotato",
    "cls": "cls"
  },
  "dependencies": {
    "@mapotato-pkg/hello-wasm": "^0.2.0",
    "@tresjs/cientos": "^4.1.0",
    "@tresjs/core": "^4.3.3",
    "@tresjs/post-processing": "^2.4.0",
    "@vueuse/components": "^12.0.0",
    "@vueuse/core": "^10.11.0",
    "big.js": "^6.2.2",
    "highlight.js": "^11.10.0",
    "monaco-editor": "^0.50.0",
    "monaco-themes": "^0.4.4",
    "rxjs": "^7.8.1",
    "three": "^0.173.0",
    "vite-plugin-ejs": "^1.7.0",
    "vite-plugin-wasm": "^3.4.1",
    "vue": "^3.4.21",
    "vue-draggable-plus": "^0.3.5",
    "vue-icons-plus": "^0.1.7",
    "vue-router": "^4.3.0",
    "vue-showdown": "^4.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.5",
    "@babel/eslint-parser": "^7.24.5",
    "@babel/preset-env": "^7.28.0",
    "@rushstack/eslint-patch": "^1.3.3",
    "@tsconfig/node20": "^20.1.2",
    "@types/babel__core": "^7.20.5",
    "@types/big.js": "^6.2.2",
    "@types/ejs": "^3.1.5",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.14.11",
    "@types/three": "^0.173.0",
    "@types/web-bluetooth": "^0.0.21",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vitejs/plugin-vue-jsx": "^3.1.0",
    "@vue/tsconfig": "^0.5.1",
    "eslint": "^9.4.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-vue": "^10.4.0",
    "npm-run-all2": "^6.1.2",
    "prettier": "^3.6.2",
    "sass": "^1.72.0",
    "typescript": "~5.4.0",
    "vite": "^5.1.6",
    "vite-bundle-analyzer": "^0.10.3",
    "vite-plugin-markdown": "^2.2.0",
    "vite-plugin-monaco-editor": "^1.1.0",
    "vue-eslint-parser": "^10.0.0",
    "vue-tsc": "^2.0.6"
  }
}
