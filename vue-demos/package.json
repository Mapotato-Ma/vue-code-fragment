{
  "name": "vue-demos",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "preview": "vite preview",
    "preview:prod": "vite preview --port 5050",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "format": "prettier --write src/",
    "build": "run-p type-check build:prod",
    "build:prod": "vite build --mode production",
    "build:analyze": "vite build --mode analyze",
    "deploy": "run-s build:prod zip upload unzip-remote",
    "zip": "powershell -Command \"Compress-Archive -Path ./mapotato/* mapotato.zip -Force\"",
    "upload": "scp ./mapotato.zip 腾讯云:/var/www/html/",
    "unzip-remote": "ssh 腾讯云 \"cd /var/www/html && rm -rf mapotato/* && unzip -o mapotato.zip -d mapotato\""
  },
  "dependencies": {
    "@mapotato-pkg/hello-wasm": "^0.2.0",
    "@tresjs/cientos": "^5.0.0",
    "@tresjs/core": "^5.0.2",
    "@tresjs/post-processing": "^2.4.0",
    "@vueuse/components": "^13.6.0",
    "@vueuse/core": "^13.6.0",
    "big.js": "^7.0.1",
    "highlight.js": "^11.11.1",
    "monaco-editor": "^0.52.2",
    "monaco-themes": "^0.4.6",
    "rxjs": "^7.8.2",
    "three": "^0.179.1",
    "vite-plugin-ejs": "^1.7.0",
    "vite-plugin-wasm": "^3.5.0",
    "vue": "^3.5.18",
    "vue-data-ui": "^3.15.12",
    "vue-draggable-plus": "^0.6.0",
    "vue-icons-plus": "^0.1.8",
    "vue-router": "^4.5.1",
    "vue-showdown": "^4.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/eslint-parser": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "@rushstack/eslint-patch": "^1.12.0",
    "@tsconfig/node20": "^20.1.6",
    "@types/babel__core": "^7.20.5",
    "@types/big.js": "^6.2.2",
    "@types/ejs": "^3.1.5",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.2.1",
    "@types/three": "^0.179.0",
    "@types/web-bluetooth": "^0.0.21",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitejs/plugin-vue-jsx": "^5.0.1",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.4.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.6.2",
    "sass": "^1.90.0",
    "terser": "^5.43.1",
    "typescript": "~5.9.2",
    "vite": "^7.1.2",
    "vite-bundle-analyzer": "^1.2.1",
    "vite-plugin-markdown": "^2.2.0",
    "vite-plugin-monaco-editor": "^1.1.0",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.0.5"
  }
}
